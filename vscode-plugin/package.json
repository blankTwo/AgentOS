{
  "name": "agent-os-vscode-plugin",
  "displayName": "Agent OS",
  "description": "用于将 Agent OS 注入工作区并查看状态的 VSCode 插件。",
  "version": "1.0.0",
  "publisher": "blankTwo",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/blankTwo/AgentOS.git",
    "directory": "vscode-plugin"
  },
  "bugs": {
    "url": "https://github.com/blankTwo/AgentOS/issues"
  },
  "homepage": "https://github.com/blankTwo/AgentOS#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onView:agentOsStatus",
    "onCommand:agentOs.injectWorkspace",
    "onCommand:agentOs.uninstallWorkspace",
    "onCommand:agentOs.refreshStatus",
    "onCommand:agentOs.openOverview",
    "onCommand:agentOs.configureIntentCompiler",
    "onCommand:agentOs.testIntentCompiler"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentOs.injectWorkspace",
        "title": "Agent OS：注入当前工作区"
      },
      {
        "command": "agentOs.uninstallWorkspace",
        "title": "Agent OS：卸载当前工作区"
      },
      {
        "command": "agentOs.refreshStatus",
        "title": "Agent OS：刷新状态"
      },
      {
        "command": "agentOs.openOverview",
        "title": "Agent OS：打开总览"
      },
      {
        "command": "agentOs.configureIntentCompiler",
        "title": "Agent OS：配置意图编译器"
      },
      {
        "command": "agentOs.testIntentCompiler",
        "title": "Agent OS：测试意图编译器"
      }
    ],
    "configuration": {
      "title": "Agent OS",
      "properties": {
        "agentOS.intentCompiler.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用 LLM Semantic Compiler。未启用或调用失败时使用本地规则算法。"
        },
        "agentOS.intentCompiler.provider": {
          "type": "string",
          "default": "custom",
          "enum": ["custom", "openai", "anthropic", "google", "qwen", "deepseek"],
          "description": "LLM Provider 标识，仅用于状态展示和运行记录。"
        },
        "agentOS.intentCompiler.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible API base URL，例如 https://api.openai.com/v1。"
        },
        "agentOS.intentCompiler.model": {
          "type": "string",
          "default": "",
          "description": "用于 Mission IR 编译的模型名称。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentOsContainer",
          "title": "Agent OS",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentOsContainer": [
        {
          "id": "agentOsStatus",
          "name": "状态",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "prepare:agent-os": "node scripts/sync-agent-os.js",
    "prepack": "npm run prepare:agent-os",
    "check": "node -c extension.js && node -c runtime/local-runtime.js && node scripts/sync-agent-os.js --dry-run",
    "package": "npm run prepare:agent-os && npx @vscode/vsce package"
  },
  "devDependencies": {},
  "license": "MIT"
}
